@section('scripts')
<script>
    // Variables globales
    let shareModal;
    let currentPlatform = null;
    let countdownInterval = null;
    
    const socialPlatforms = [
        { key: 'facebook', name: 'Facebook', icon: '📘', points: 5, color: '#1877F2' },
        { key: 'twitter', name: 'Twitter/X', icon: '🐦', points: 5, color: '#1DA1F2' },
        { key: 'linkedin', name: 'LinkedIn', icon: '💼', points: 5, color: '#0A66C2' },
        { key: 'whatsapp', name: 'WhatsApp', icon: '💬', points: 5, color: '#25D366' },
        { key: 'telegram', name: 'Telegram', icon: '✈️', points: 5, color: '#0088cc' },
    ];
    
    const shareUrls = {
        facebook: 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(window.location.origin),
        twitter: 'https://twitter.com/intent/tweet?url=' + encodeURIComponent(window.location.origin) + '&text=' + encodeURIComponent('Découvrez ProxiPro, la meilleure plateforme de services ! 🚀'),
        linkedin: 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(window.location.origin),
        whatsapp: 'https://wa.me/?text=' + encodeURIComponent('Découvrez ProxiPro, la meilleure plateforme de services ! 🚀 ' + window.location.origin),
        telegram: 'https://t.me/share/url?url=' + encodeURIComponent(window.location.origin) + '&text=' + encodeURIComponent('Découvrez ProxiPro, la meilleure plateforme de services ! 🚀'),
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        shareModal = new bootstrap.Modal(document.getElementById('shareModal'));
        
        // Tab switching
        document.querySelectorAll('.section-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                const tabName = this.dataset.tab;
                
                document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.section-content').forEach(c => c.classList.remove('active'));
                
                this.classList.add('active');
                document.getElementById(tabName + '-section').classList.add('active');
            });
        });
        
        // Load social status
        loadSocialStatus();
        
        // Check URL params
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('canceled') === 'true') {
            showToast('Paiement annulé', 'error');
            window.history.replaceState({}, '', '/pricing');
        }
    });
    
    function showToast(message, type = 'success') {
        const toast = document.getElementById('toast-notification');
        toast.textContent = message;
        toast.className = 'toast-notification ' + type;
        toast.style.display = 'block';
        
        setTimeout(() => {
            toast.style.display = 'none';
        }, 5000);
    }
    
    function purchasePoints(productKey, button) {
        const originalText = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Redirection...';
        
        fetch('{{ route("stripe.create-checkout") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': '{{ csrf_token() }}'
            },
            body: JSON.stringify({ product_key: productKey })
        })
        .then(res => res.json())
        .then(data => {
            if (data.url) {
                window.location.href = data.url;
            } else {
                showToast(data.error || 'Erreur lors du paiement', 'error');
                button.disabled = false;
                button.innerHTML = originalText;
            }
        })
        .catch(err => {
            showToast('Erreur réseau', 'error');
            button.disabled = false;
            button.innerHTML = originalText;
        });
    }
    
    function loadSocialStatus() {
        fetch('{{ route("social.status") }}')
            .then(res => res.json())
            .then(data => {
                renderSocialPlatforms(data);
            })
            .catch(() => {
                document.getElementById('social-platforms').innerHTML = '<div class="col-12 text-center text-white-50">Erreur de chargement</div>';
            });
    }
    
    function renderSocialPlatforms(status) {
        const container = document.getElementById('social-platforms');
        const claimed = status.claimed_platforms || [];
        
        document.getElementById('total-social-earned').textContent = 
            status.total_earned + ' / ' + status.max_possible + ' points réclamés';
        
        let html = '';
        socialPlatforms.forEach(platform => {
            const isClaimed = claimed.includes(platform.key);
            html += `
                <div class="col-6 col-md-4 col-lg">
                    <div class="social-platform-card ${isClaimed ? 'claimed' : ''}">
                        <div class="social-icon">${platform.icon}</div>
                        <h5 class="text-white mb-2">${platform.name}</h5>
                        <div class="social-points">+${platform.points} pts</div>
                        <button class="btn btn-share mt-3" 
                                onclick="startSocialShare('${platform.key}')"
                                ${isClaimed ? 'disabled' : ''}>
                            ${isClaimed ? '<i class="fas fa-check me-2"></i>Réclamé' : '<i class="fas fa-share-alt me-2"></i>Partager'}
                        </button>
                        ${isClaimed ? '<p class="text-white-50 small mt-2 mb-0">Vous pouvez toujours partager librement</p>' : ''}
                    </div>
                </div>
            `;
        });
        
        container.innerHTML = html;
    }
    
    function startSocialShare(platformKey) {
        currentPlatform = socialPlatforms.find(p => p.key === platformKey);
        if (!currentPlatform) return;
        
        // Show modal with "sharing" step
        showShareStep('sharing');
        shareModal.show();
        
        // Open share window
        const shareWindow = window.open(shareUrls[platformKey], '_blank', 'width=600,height=500');
        
        if (!shareWindow || shareWindow.closed) {
            showShareStep('popup_blocked');
            return;
        }
        
        // Start 30-second countdown immediately (user must wait 30 seconds)
        startCountdown(30);
    }
    
    function showShareStep(step, message = '') {
        const content = document.getElementById('share-modal-content');
        let html = '';
        
        switch(step) {
            case 'sharing':
                html = `
                    <div class="share-step">
                        <div class="icon-container bg-light">${currentPlatform.icon}</div>
                        <h4>Partagez sur ${currentPlatform.name}</h4>
                        <p class="text-muted">Complétez le partage dans la fenêtre qui s'est ouverte...</p>
                        <div class="spinner-border text-primary mt-3"></div>
                        <p class="text-muted small mt-3">Veuillez patienter 30 secondes pour la vérification</p>
                    </div>
                `;
                break;
                
            case 'countdown':
                html = `
                    <div class="share-step">
                        <div class="countdown-circle" id="countdown-number">30</div>
                        <h4>Vérification en cours...</h4>
                        <p class="text-muted">Veuillez patienter pendant la vérification du partage</p>
                        <p class="text-muted small">Ne fermez pas cette fenêtre</p>
                    </div>
                `;
                break;
                
            case 'confirm':
                html = `
                    <div class="share-step">
                        <div class="icon-container" style="background: rgba(16, 185, 129, 0.1);">
                            <i class="fas fa-question-circle text-success" style="font-size: 50px;"></i>
                        </div>
                        <h4>Avez-vous partagé sur ${currentPlatform.name} ?</h4>
                        <p class="text-muted mb-4">Confirmez pour recevoir vos <strong>${currentPlatform.points} points gratuits</strong></p>
                        <div class="d-flex gap-3 justify-content-center">
                            <button class="btn btn-outline-secondary px-4" onclick="shareModal.hide()">Annuler</button>
                            <button class="btn btn-success px-4" onclick="confirmShare()">
                                <i class="fas fa-check me-2"></i>Oui, j'ai partagé !
                            </button>
                        </div>
                    </div>
                `;
                break;
                
            case 'crediting':
                html = `
                    <div class="share-step">
                        <div class="spinner-grow spinner-grow-custom text-primary"></div>
                        <h4 class="mt-4">Crédit des points en cours...</h4>
                    </div>
                `;
                break;
                
            case 'success':
                html = `
                    <div class="share-step">
                        <div class="icon-container" style="background: rgba(16, 185, 129, 0.1);">
                            <i class="fas fa-check-circle text-success" style="font-size: 50px;"></i>
                        </div>
                        <h4 class="text-success">🎉 +${currentPlatform.points} points !</h4>
                        <p class="text-muted">${message || 'Merci pour votre partage !'}</p>
                        <p class="text-muted small">Vous pouvez toujours partager sur ${currentPlatform.name} librement, mais vous ne gagnerez plus de points sur ce réseau.</p>
                    </div>
                `;
                break;
                
            case 'popup_blocked':
                html = `
                    <div class="share-step">
                        <div class="icon-container" style="background: rgba(239, 68, 68, 0.1);">
                            <i class="fas fa-exclamation-triangle text-warning" style="font-size: 50px;"></i>
                        </div>
                        <h4>Popup bloquée</h4>
                        <p class="text-muted">Veuillez autoriser les popups dans votre navigateur pour partager sur ${currentPlatform.name}.</p>
                        <button class="btn btn-outline-secondary mt-3" onclick="shareModal.hide()">Fermer</button>
                    </div>
                `;
                break;
                
            case 'error':
                html = `
                    <div class="share-step">
                        <div class="icon-container" style="background: rgba(239, 68, 68, 0.1);">
                            <i class="fas fa-times-circle text-danger" style="font-size: 50px;"></i>
                        </div>
                        <h4 class="text-danger">Erreur</h4>
                        <p class="text-muted">${message}</p>
                        <button class="btn btn-outline-secondary mt-3" onclick="shareModal.hide()">Fermer</button>
                    </div>
                `;
                break;
        }
        
        content.innerHTML = html;
    }
    
    function startCountdown(seconds) {
        showShareStep('countdown');
        let count = seconds;
        
        const el = document.getElementById('countdown-number');
        if (el) el.textContent = count;
        
        countdownInterval = setInterval(() => {
            count--;
            const el = document.getElementById('countdown-number');
            if (el) el.textContent = count;
            
            if (count <= 0) {
                clearInterval(countdownInterval);
                showShareStep('confirm');
            }
        }, 1000);
    }
    
    function confirmShare() {
        showShareStep('crediting');
        
        fetch('{{ route("social.share") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
                'X-CSRF-TOKEN': '{{ csrf_token() }}',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ platform: currentPlatform.key })
        })
        .then(res => {
            if (!res.ok) {
                return res.json().then(data => {
                    throw { status: res.status, data: data };
                }).catch(() => {
                    throw { status: res.status, data: { error: 'Erreur serveur (' + res.status + ')' } };
                });
            }
            return res.json();
        })
        .then(data => {
            if (data.success) {
                showShareStep('success', data.message);
                document.getElementById('user-points').textContent = 
                    new Intl.NumberFormat('fr-FR').format(data.new_balance) + ' points';
                
                setTimeout(() => {
                    shareModal.hide();
                    loadSocialStatus();
                }, 3000);
            } else {
                if (data.already_claimed) {
                    showShareStep('error', 'Vous avez déjà réclamé vos points pour ce réseau. Vous pouvez toujours partager librement !');
                } else {
                    showShareStep('error', data.error || 'Erreur lors du crédit des points');
                }
            }
        })
        .catch(err => {
            console.error('Social share error:', err);
            const errorMsg = err.data?.error || err.data?.message || 'Erreur réseau. Veuillez réessayer.';
            showShareStep('error', errorMsg);
        });
    }
</script>
@endsection
